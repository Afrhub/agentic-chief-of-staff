# ============================================================================
# AI Chief of Staff — self-hosted (single-tenant) configuration
# Copy to `.env` and fill in. This file (the real .env) stays on YOUR server.
# Nothing here is ever sent to the vendor.
# ============================================================================

# ---- Database (runs in this stack; data never leaves your host) ----
POSTGRES_USER=cos
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=chief_of_staff
# Backend connection string (points at the `db` service in compose)
DATABASE_URL=postgresql://cos:change-me-strong-password@db:5432/chief_of_staff

# ---- LLM inference (see docs/llm-inference.md) ----
# MODE A (default): your own cloud keys. Prompt content goes to the model
#   vendor under YOUR account's terms — never to us.
LLM_MODE=cloud
ANTHROPIC_API_KEY=sk-ant-your-own-key
OPENAI_API_KEY=sk-your-own-key
# Optional model overrides:
# LLM_PRIMARY_MODEL=claude-sonnet-4-6
# LLM_FALLBACK_MODEL=gpt-4-turbo
# LLM_LAST_RESORT_MODEL=claude-haiku-4-5
# LLM_EMBED_MODEL=text-embedding-3-small
#
# MODE B (strict): fully local — nothing leaves the host. Requires a GPU and
#   the `local-llm` compose profile (or your own OpenAI-compatible server).
# LLM_MODE=local
# LLM_LOCAL_BASE_URL=http://ollama:11434/v1
# LLM_LOCAL_MODEL=llama3.1:70b
# LLM_LOCAL_EMBED_MODEL=nomic-embed-text
# LLM_LOCAL_API_KEY=local

# ---- Integrations (your own app credentials / tokens) ----
SLACK_BOT_TOKEN=xoxb-your-workspace-token
SLACK_SIGNING_SECRET=your-slack-signing-secret   # required for the /slack/events bot (verifies Slack requests)

# WhatsApp chief-of-staff bot (Twilio) — POST /whatsapp/events
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
STRIPE_API_KEY=sk_live_your-key
# Google OAuth — request scopes: calendar.readonly, gmail.readonly, gmail.send
# (gmail.send lets the chief of staff actually send approved email drafts)
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# ---- Licensing (offline; we never see your data) ----
# Signed license key validates the install without phoning home with PII.
LICENSE_KEY=

# ---- Ports ----
WEB_PORT=8080
